# The source code demonstrates the built-in mathematical functions.

let a = 25;
let b = 2;
let c = 1;

# Built-in sin function.
print(sin(0));      # sin(0) = 0
print(sin(c));      # sin(c) = sin(1)

# Built-in cos function.
print(cos(c));      # cos(c) = cos(1)
print(cos(0));      # cos(0) = 1

# Built-in sqrt, abs, log2, log, and ln functions.
print(sqrt(a));     # sqrt(a) = 5
print(abs(-c));     # abs(-c) = 1
print(log2(b));     # log2(b) = 1
print(log(b));      # log(b) = log(2)
print(ln(b));       # ln(b) = ln(2)

# Built-in min and max functions.
print(min(a, 30));
print(max(a, b));